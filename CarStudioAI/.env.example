# =============================================================================
# Car Studio AI - Variáveis de Ambiente
# =============================================================================
# Copie este arquivo para .env.local e preencha com seus valores reais
# NUNCA commite .env.local no git (já está no .gitignore)
# =============================================================================

# --------------------------------------
# Google Gemini AI (Geração de Imagens)
# --------------------------------------
# Chave de API do Google AI Studio para geração de imagens
# Obtenha em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# --------------------------------------
# Supabase - Banco de Dados e Autenticação
# --------------------------------------
# Estas variáveis têm prefixo NEXT_PUBLIC_ e são expostas no browser
# É seguro expor estas chaves (são "anon keys" com permissões limitadas)
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-aqui

# --------------------------------------
# Supabase - Server Only (NUNCA exponha no browser!)
# --------------------------------------
# Service Role Key tem acesso total ao banco de dados
# Use apenas em código server-side (API Routes, Server Components)
# Se vazar, alguém pode acessar/modificar todos os dados
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key-aqui

# --------------------------------------
# Hub (Área de Membros Integrada) - Opcional
# --------------------------------------
# URL da API de handoff do Hub para login integrado
# Se configurado, usuários logados no Hub acessam automaticamente
HUB_CARSTUDIO_LOGIN_URL=https://membros.allanfulcher.com/api/auth/car-studio/start

# Segredo JWT para validar tokens vindos do Hub
# Deve ser o mesmo valor configurado no Hub
HUB_JWT_SECRET=segredo-jwt-de-pelo-menos-32-caracteres

# URL base da aplicação (usada em redirects)
# Exemplos: http://localhost:3000 (dev) ou https://carstudio.vercel.app (prod)
CAR_STUDIO_BASE_URL=

# Para onde redirecionar após login bem-sucedido
CAR_STUDIO_DEFAULT_REDIRECT=/studio

# --------------------------------------
# Administração
# --------------------------------------
# Lista de e-mails com acesso à área /admin (separados por vírgula)
# Apenas estes e-mails podem consultar/ajustar créditos de usuários
CAR_STUDIO_ADMIN_EMAILS=admin1@email.com,admin2@email.com
